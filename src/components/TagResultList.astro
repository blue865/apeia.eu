---
/**
 * Tag result page body.
 * Groups entries by type (Posts → Galleries → Images), each sorted by date desc.
 * Empty groups are omitted entirely.
 */
import { Image } from 'astro:assets';
import { formatDate } from '../lib/format.ts';
import type { TagEntry } from '../lib/tags.ts';

interface Props {
  section: 'astro' | 'shards';
  tag: string;
  entries: TagEntry[];
}
const { tag, entries } = Astro.props;

const posts     = entries.filter((e): e is Extract<TagEntry, { type: 'post' }>    => e.type === 'post');
const galleries = entries.filter((e): e is Extract<TagEntry, { type: 'gallery' }> => e.type === 'gallery');
const images    = entries.filter((e): e is Extract<TagEntry, { type: 'image' }>   => e.type === 'image');
---

{entries.length === 0 && (
  <p class="empty">Nothing tagged <strong>{tag}</strong> yet.</p>
)}

{posts.length > 0 && (
  <section class="group">
    <h2>Posts</h2>
    <ul class="post-list">
      {posts.map((p) => (
        <li>
          <a href={p.href}>
            <span class="date">{formatDate(p.date)}</span>
            <span class="body">
              <span class="title">{p.title}</span>
              {p.summary && <span class="summary">{p.summary}</span>}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

{galleries.length > 0 && (
  <section class="group">
    <h2>Galleries</h2>
    <ul class="card-grid">
      {galleries.map((g) => (
        <li>
          <a class="card" href={g.href}>
            {g.thumbnail && <Image src={g.thumbnail} alt={g.title} width={520} height={520} class="thumb" />}
            <span class="card-meta">
              <span class="card-title">{g.title}</span>
              <span class="card-sub">{formatDate(g.date)}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

{images.length > 0 && (
  <section class="group">
    <h2>Images</h2>
    <ul class="image-grid">
      {images.map((im) => (
        <li>
          <a class="image" href={im.href}>
            <Image src={im.thumbnail} alt={im.caption ?? im.title} width={520} height={520} />
            <span class="image-meta">
              <span class="image-caption">{im.caption ?? '—'}</span>
              <span class="image-parent">{im.title}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .empty { color: var(--color-text-muted); }
  .group { margin: var(--space-7) 0; }
  .group h2 {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border-soft);
    padding-bottom: var(--space-2);
    margin: 0 0 var(--space-4);
  }

  .post-list { list-style: none; margin: 0; padding: 0; }
  .post-list li { border-bottom: 1px solid var(--color-border-soft); }
  .post-list a {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: var(--space-5);
    padding: var(--space-4) 0;
    align-items: baseline;
    color: var(--color-text);
    border-bottom: none;
  }
  .post-list a:hover .title { color: var(--accent); }
  .date { color: var(--color-text-muted); font-family: var(--font-mono); font-size: var(--fs-xs); }
  .body { display: flex; flex-direction: column; }
  .title { color: rgba(226, 228, 234, var(--text-high)); font-weight: 500; transition: color var(--t-fast); }
  .summary { color: rgba(226, 228, 234, var(--text-medium)); font-size: var(--fs-sm); margin-top: 0.2em; }

  .card-grid, .image-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-4);
  }

  .card { display: block; color: var(--color-text); border-bottom: none; }
  .card:hover .card-title { color: var(--accent); }
  .thumb {
    width: 100%; aspect-ratio: 1/1; object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--color-border-soft);
  }
  body[data-section="shards"] .thumb { border-radius: 0; clip-path: var(--motif-shards-cut); }
  .card-meta { display: flex; flex-direction: column; margin-top: var(--space-2); }
  .card-title { font-size: var(--fs-sm); font-weight: 500; transition: color var(--t-fast); }
  .card-sub { color: var(--color-text-muted); font-size: var(--fs-xs); font-family: var(--font-mono); }

  .image { display: block; color: var(--color-text); border-bottom: none; }
  .image :global(img) {
    width: 100%; aspect-ratio: 1/1; object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--color-border-soft);
  }
  body[data-section="shards"] .image :global(img) { border-radius: 0; clip-path: var(--motif-shards-cut); }
  .image-meta { display: flex; flex-direction: column; margin-top: var(--space-2); }
  .image-caption { font-size: var(--fs-sm); color: rgba(226, 228, 234, var(--text-body)); }
  .image-parent { color: var(--color-text-muted); font-size: var(--fs-xs); font-family: var(--font-mono); }

  @media (max-width: 600px) {
    .post-list a { grid-template-columns: 1fr; gap: 0.2em; }
  }
</style>

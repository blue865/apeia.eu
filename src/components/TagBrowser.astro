---
/**
 * Tag browser — a scrollable grid of tag pills with counts.
 * Sorted by count desc, then a–z.
 */
import TagPill from './TagPill.astro';
import { sortedTagSummary } from '../lib/tags.ts';
import type { TagEntry } from '../lib/tags.ts';

interface Props {
  section: 'astro' | 'shards';
  tags: Map<string, TagEntry[]>;
}
const { section, tags } = Astro.props;
const summary = sortedTagSummary(tags);
---

<div class="browser">
  {summary.length === 0 ? (
    <p class="empty">No tags yet.</p>
  ) : (
    <ul class="tags">
      {summary.map(({ tag, count }) => (
        <li><TagPill tag={tag} count={count} section={section} /></li>
      ))}
    </ul>
  )}
</div>

<style>
  .browser { margin: var(--space-5) 0; }
  .tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }
  .empty { color: var(--color-text-muted); font-style: italic; }
</style>

---
import { formatDate } from '../lib/format.ts';
interface Props {
  href: string;
  title: string;
  date: Date;
  summary?: string;
  topic?: string;
}
const { href, title, date, summary, topic } = Astro.props;
---

<li class="card">
  <a href={href}>
    <span class="meta">
      <time datetime={date.toISOString()} class="date">{formatDate(date)}</time>
      {topic && <span class="topic">{topic}</span>}
    </span>
    <span class="body">
      <span class="title">{title}</span>
      {summary && <span class="summary">{summary}</span>}
    </span>
  </a>
</li>

<style>
  .card { border-bottom: 1px solid var(--color-border-soft); }
  .card:first-child { border-top: 1px solid var(--color-border-soft); }
  a {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: var(--space-5);
    padding: var(--space-5) 0;
    align-items: baseline;
    color: var(--color-text);
    border-bottom: none;
  }
  a:hover { border-bottom: none; }
  a:hover .title { color: var(--accent); }

  .meta { display: flex; flex-direction: column; gap: 0.3em; }
  .date {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }
  .topic {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.10em;
    text-transform: uppercase;
  }

  .body { display: flex; flex-direction: column; }
  .title {
    color: rgba(226, 228, 234, var(--text-high));
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 400;
    line-height: 1.25;
    transition: color var(--t-fast);
  }
  .summary {
    color: rgba(226, 228, 234, var(--text-medium));
    font-size: var(--fs-sm);
    margin-top: 0.3em;
    max-width: var(--measure);
  }

  @media (max-width: 600px) {
    a { grid-template-columns: 1fr; gap: 0.3em; }
  }
</style>

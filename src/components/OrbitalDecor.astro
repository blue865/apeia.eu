---
/**
 * Astro section motif: concentric orbital rings.
 * Decorative only — sits behind hero content.
 */
interface Props {
  variant?: 'hero' | 'block';
}
const { variant = 'hero' } = Astro.props;
---

<svg
  class:list={['orbital', `variant-${variant}`]}
  viewBox="0 0 600 600"
  aria-hidden="true"
  preserveAspectRatio="xMidYMid meet"
>
  <defs>
    <radialGradient id="orb-fade" cx="50%" cy="50%" r="50%">
      <stop offset="0%"   stop-color="currentColor" stop-opacity="0.55"/>
      <stop offset="80%"  stop-color="currentColor" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="currentColor" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <g fill="none" stroke="currentColor" stroke-width="1">
    <circle cx="300" cy="300" r="80"  opacity="0.45"/>
    <circle cx="300" cy="300" r="160" opacity="0.30"/>
    <circle cx="300" cy="300" r="240" opacity="0.18"/>
    <circle cx="300" cy="300" r="295" opacity="0.10"/>
  </g>
  <!-- two small bodies on orbits -->
  <circle cx="380" cy="300" r="2.5" fill="currentColor" opacity="0.85"/>
  <circle cx="300" cy="140" r="1.8" fill="currentColor" opacity="0.65"/>
  <circle cx="540" cy="300" r="1.4" fill="currentColor" opacity="0.4"/>
</svg>

<style>
  .orbital {
    color: var(--accent);
    pointer-events: none;
    position: absolute;
  }
  .variant-hero {
    inset: -10% -10% auto auto;
    width: min(860px, 90vw);
    height: min(860px, 90vw);
    opacity: 0.6;
  }
  .variant-block {
    width: 100%;
    max-width: 420px;
    opacity: 0.45;
    position: relative;
    inset: auto;
  }
</style>

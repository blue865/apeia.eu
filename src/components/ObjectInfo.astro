---
/**
 * Object info card for an Astro gallery.
 *
 * Every field is optional. If all five are missing, the component renders
 * nothing. Layout is a <dl> grid with monospace uppercase labels in the left
 * column and free-form values in the right column.
 *
 * Note: this card no longer renders its own heading — the gallery title
 * already names the object on the page, so a duplicate would be noise.
 */
export type ObjectInfo = {
  constellation?: string;
  position?: string;
  culmination?: string;
  distance?: string;
  size?: string;
  apparentSize?: string;
};

interface Props {
  data?: ObjectInfo;
}

const { data } = Astro.props;

/**
 * Position is conventionally written as "RA … · Dec …" (the two parts of a
 * celestial coordinate separated by ` · `). Split it so each part lives on
 * its own line in the card — pure-string fallback if no separator is found.
 */
function splitPosition(value: string): string[] {
  const trimmed = value.trim();
  if (!trimmed) return [];
  // Accept the conventional " · " separator, plus a few near-misses to be
  // forgiving of authoring style (regular dot with surrounding spaces, or a
  // semicolon).
  const parts = trimmed.split(/\s+[·•|;]\s+/);
  return parts.map((p) => p.trim()).filter(Boolean);
}

type Field = { label: string; lines: string[] };

const fields: Field[] = [
  { label: 'Position',      lines: splitPosition(data?.position ?? '') },
  { label: 'Culmination',   lines: [data?.culmination ?? ''] },
  { label: 'Distance',      lines: [data?.distance ?? ''] },
  { label: 'Size',          lines: [data?.size ?? ''] },
  { label: 'Apparent size', lines: [data?.apparentSize ?? ''] },
  { label: 'Constellation', lines: [data?.constellation ?? ''] },
]
  .map((f) => ({ ...f, lines: f.lines.map((l) => l.trim()).filter(Boolean) }))
  .filter((f) => f.lines.length > 0);
---

{fields.length > 0 && (
  <aside class="object-info" aria-label="Object information">
    <dl>
      {fields.map((f) => (
        <>
          <dt>{f.label}</dt>
          <dd>
            {f.lines.map((line, i) => (
              <>
                {i > 0 && <br />}
                {line}
              </>
            ))}
          </dd>
        </>
      ))}
    </dl>
  </aside>
)}

<style>
  .object-info {
    padding: var(--space-5);
    background: rgba(var(--bg-rgb, 17, 19, 24), 0.2);
    backdrop-filter: blur(8px) saturate(115%);
    -webkit-backdrop-filter: blur(8px) saturate(115%);
    border: 1px solid var(--color-border-soft);
    border-right: 2px solid var(--accent-line);
    border-radius: var(--radius);
  }

  dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-2) var(--space-5);
    margin: 0;
  }
  dt {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    align-self: baseline;
    white-space: nowrap;
  }
  dd {
    margin: 0;
    color: rgba(226, 228, 234, var(--text-body));
    font-size: var(--fs-sm);
    /* Each line is a self-contained value (e.g. an RA coordinate); keep it
       on a single line so it doesn't wrap mid-coordinate. The <br>s between
       lines still introduce the intended line breaks. */
    white-space: nowrap;
  }

  @media (max-width: 540px) {
    dl {
      grid-template-columns: 1fr;
      gap: var(--space-1) 0;
    }
    dt { padding-top: var(--space-2); }
    dt:first-of-type { padding-top: 0; }
  }
</style>

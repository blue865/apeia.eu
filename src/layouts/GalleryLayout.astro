---
import { Image } from 'astro:assets';
import Base from './Base.astro';
import TagPill from '../components/TagPill.astro';
import ObjectInfo, { type ObjectInfo as ObjectInfoData } from '../components/ObjectInfo.astro';
import { formatDateLong } from '../lib/format.ts';
import { normalizeTags } from '../lib/tags.ts';
import { buildDownloadOptions, type DownloadOption, type GalleryCollection } from '../lib/galleryDownloads.ts';

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  cover?: ImageMetadata;
  section: 'astro' | 'shards';
  /** Gallery slug (used to resolve original filenames for download options). */
  slug: string;
  /** Optional astronomical metadata; only meaningful for the Astro section. */
  objectInfo?: ObjectInfoData;
  images: Array<{
    file: ImageMetadata;
    alt?: string;
    caption?: string;
    tags?: string[];
  }>;
}
const { title, date, description, tags = [], cover, section, slug, objectInfo, images } = Astro.props;
const galleryTags = normalizeTags(tags);
const heroImage = cover ?? images[0]?.file;

// Build per-image download options. The helper resolves the original filename
// via Vite's `import.meta.glob('?raw')` on meta.yaml, so it works in both dev
// and build (no fs / import.meta.url path-walk needed here).
const collection: GalleryCollection = section === 'astro' ? 'astro-gallery' : 'shards-gallery';
const downloads: DownloadOption[][] = await Promise.all(
  images.map((_img, i) =>
    buildDownloadOptions({
      imageMeta: images[i].file,
      collection,
      gallerySlug: slug,
      imageIndex: i,
    }),
  ),
);
---

<Base title={title} description={description} section={section}>
  <article class="gallery">
    {section === 'astro' && heroImage ? (
      <section class="hero grain">
        <Image src={heroImage} alt={title} width={2000} height={1200} class="hero-img" loading="eager" />
        <div class="hero-veil"></div>
        <div class="header-row container-wide on-hero">
          <header class="gallery-header">
            <p class="meta">
              <a href={`/${section}/gallery/`} class="back">← Astro gallery</a>
            </p>
            <h1>{title}</h1>
            {description && <p class="lede">{description}</p>}
            <p class="when">
              <time datetime={date.toISOString()}>{formatDateLong(date)}</time>
              <span class="dot">·</span>
              <span>{images.length} {images.length === 1 ? 'image' : 'images'}</span>
            </p>
          </header>

          {objectInfo && (
            <aside class="header-side">
              <ObjectInfo data={objectInfo} />
            </aside>
          )}
        </div>
        <div class="hero-fade"></div>
      </section>
    ) : (
      <div class="header-row container-wide">
        <header class="gallery-header">
          <p class="meta">
            <a href={`/${section}/gallery/`} class="back">← {section === 'astro' ? 'Astro' : 'Shards'} gallery</a>
          </p>
          <h1>{title}</h1>
          {description && <p class="lede">{description}</p>}
          <p class="when">
            <time datetime={date.toISOString()}>{formatDateLong(date)}</time>
            <span class="dot">·</span>
            <span>{images.length} {images.length === 1 ? 'image' : 'images'}</span>
          </p>
        </header>
      </div>
    )}

    <div class="container-wide images">
      {images.map((img, i) => {
        const imgUnion = Array.from(new Set([...galleryTags, ...normalizeTags(img.tags)]));
        const opts = downloads[i] ?? [];
        return (
          <figure id={`img-${i + 1}`} class="image">
            <div class="image-wrap" style={`max-width: ${img.file.width}px;`}>
              <Image
                src={img.file}
                alt={img.alt ?? img.caption ?? `${title} — ${i + 1}`}
                widths={[480, 800, 1200, 1800]}
                sizes="(min-width: 1100px) 1100px, 100vw"
                style={`max-width: min(${img.file.width}px, 100%);`}
              />
              <div class="image-actions">
                <a class="fs-btn" href={`#fs-${i + 1}`} aria-label="View fullscreen">
                  <svg class="fs-icon" viewBox="0 0 16 16" aria-hidden="true">
                    <path fill="none" stroke="currentColor" stroke-width="1.4"
                          stroke-linecap="round" stroke-linejoin="round"
                          d="M3 6V3h3 M10 3h3v3 M13 10v3h-3 M6 13H3v-3" />
                  </svg>
                </a>
                {opts.length > 0 && (
                  <details class="dl">
                    <summary aria-label="Download this image">
                      <svg class="dl-icon" viewBox="0 0 16 16" aria-hidden="true">
                        <path fill="none" stroke="currentColor" stroke-width="1.4"
                              stroke-linecap="round" stroke-linejoin="round"
                              d="M8 2v8M4 7l4 4 4-4M3 13h10" />
                      </svg>
                    </summary>
                    <ul class="dl-menu" role="menu">
                      {opts.map((o) => (
                        <li role="none">
                          <a role="menuitem" href={o.url} download={o.filename}>
                            <span class="dl-opt-label">{o.label}</span>
                            {o.isOriginal && <span class="dl-opt-badge">original</span>}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                )}
              </div>
            </div>

            {/* Fullscreen overlay — pure-CSS :target. The whole overlay is a
               link back to the in-flow figure so clicking anywhere closes. */}
            <a
              id={`fs-${i + 1}`}
              class="fs-overlay"
              href={`#img-${i + 1}`}
              aria-label="Close fullscreen"
            >
              <span class="fs-close" aria-hidden="true">
                <svg viewBox="0 0 16 16">
                  <path fill="none" stroke="currentColor" stroke-width="1.6"
                        stroke-linecap="round" stroke-linejoin="round"
                        d="M3 3l10 10M13 3L3 13" />
                </svg>
              </span>
              <Image
                src={img.file}
                alt={img.alt ?? img.caption ?? `${title} — ${i + 1}`}
                widths={[1200, 1800, 2400, 3000]}
                sizes="100vw"
                loading="lazy"
                class="fs-image"
                style={`max-width: min(${img.file.width}px, 100%); max-height: 100%;`}
              />
            </a>

            {(img.caption || imgUnion.length > 0) && (
              <figcaption>
                {img.caption && <span class="caption">{img.caption}</span>}
                {imgUnion.length > 0 && (
                  <span class="img-tags">
                    {imgUnion.map((t) => (
                      <TagPill tag={t} section={section} size="sm" />
                    ))}
                  </span>
                )}
              </figcaption>
            )}
          </figure>
        );
      })}
    </div>

    {galleryTags.length > 0 && (
      <footer class="container tags">
        <span class="label">Gallery tagged</span>
        <ul>
          {galleryTags.map((t) => (
            <li><TagPill tag={t} section={section} size="sm" /></li>
          ))}
        </ul>
      </footer>
    )}
  </article>
</Base>

<style>
  .gallery { padding-bottom: var(--space-7); }

  .hero {
    position: relative;
    width: 100%;
    max-height: 78vh;
    overflow: hidden;
  }
  .hero-img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
  .hero-fade {
    position: absolute;
    inset: auto 0 0 0;
    height: 30%;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent, var(--color-bg) 95%);
  }

  /* Header row — title/description on the left, object-info card on the right.
     Wraps to a single column on narrow viewports. */
  .header-row {
    padding: var(--space-7) var(--space-5) var(--space-5);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6) var(--space-7);
    align-items: flex-start;
  }
  .gallery-header {
    flex: 1 1 420px;
    min-width: 0;
    max-width: var(--maxw);
  }
  .header-side {
    flex: 0 0 320px;
    width: 320px;
  }
  @media (max-width: 760px) {
    .gallery-header { flex-basis: 100%; max-width: 100%; }
    .header-side    { flex: 1 1 100%; width: 100%; }
  }

  .meta { margin: 0 0 var(--space-3); font-family: var(--font-mono); font-size: var(--fs-xs); }
  .back { color: var(--color-text-muted); border-bottom: 1px solid transparent; }
  .back:hover { color: var(--accent); border-bottom-color: var(--accent); }

  h1 { font-size: var(--fs-2xl); margin: 0 0 var(--space-3); }
  .lede {
    color: rgba(226, 228, 234, var(--text-medium));
    font-size: var(--fs-md);
    max-width: var(--measure);
    margin: 0 0 var(--space-4);
  }
  .when {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
  }
  .dot { opacity: 0.6; }

  .images {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
    margin: var(--space-7) auto;
  }
  .image { margin: 0; }

  /* The wrap inherits an inline `max-width` set per image (= source width in
     px) so it never grows beyond the original's natural size; `margin: auto`
     then centres the wrap inside the column. Result: small originals are
     displayed at their natural size and centred, with the action pills
     anchored to the right edge of the image rather than the column. */
  .image-wrap {
    position: relative;
    display: block;
    margin: 0 auto;
  }

  .image :global(img) {
    /* Inline style on the img clamps max-width to the source width too, so
       even if a future change makes the wrap wider than the source, the img
       still won't upscale. */
    max-width: 100%;
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius);
  }
  body[data-section="shards"] .image :global(img) {
    border-radius: 0;
    clip-path: var(--motif-shards-cut);
  }

  figcaption {
    margin-top: var(--space-3);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--fs-sm);
  }
  .caption { color: rgba(226, 228, 234, var(--text-body)); }
  .img-tags { display: inline-flex; gap: var(--space-2); flex-wrap: wrap; }

  /* ------- Image action pills (fullscreen + download) ------- */
  /* Both pills live in a single flex strip pinned to the top-right of the
     image. Each pill is a static-positioned child so they sit side by side
     instead of overlapping. */
  .image-actions {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 2;
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
  }

  /* ------- Fullscreen pill ------- */
  .fs-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    padding: 0.45em 0.85em;
    background: rgba(17, 19, 24, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 999px;
    color: rgba(226, 228, 234, 0.92);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    cursor: pointer;
    user-select: none;
    transition: background var(--t-fast), border-color var(--t-fast), color var(--t-fast);
  }
  .fs-btn:hover {
    background: rgba(17, 19, 24, 0.92);
    border-color: var(--accent-line);
    color: var(--accent);
  }
  body[data-section="shards"] .fs-btn { border-radius: 4px; }
  .fs-icon { width: 14px; height: 14px; }
  .fs-label { letter-spacing: 0.04em; }
  @media (max-width: 640px) {
    .fs-btn .fs-label { display: none; }
    .fs-btn { padding: 0.5em; }
  }

  /* ------- Fullscreen overlay (pure-CSS via :target) ------- */
  .fs-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.96);
    align-items: center;
    justify-content: center;
    padding: var(--space-5);
    cursor: zoom-out;
    border-bottom: none;        /* override global <a> chrome */
  }
  .fs-overlay:target { display: flex; }
  .fs-overlay :global(img) {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    border: 0;
    border-radius: var(--radius);
  }
  body[data-section="shards"] .fs-overlay :global(img) {
    border-radius: 0;
    clip-path: var(--motif-shards-cut);
  }
  .fs-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(17, 19, 24, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 999px;
    color: rgba(226, 228, 234, 0.92);
    /* Visual hint only — clicks bubble up to the wrapping <a>. */
    pointer-events: none;
  }
  .fs-close svg { width: 14px; height: 14px; }
  body[data-section="shards"] .fs-close { border-radius: 4px; }

  /* ------- Download dropdown (pure-CSS <details>) ------- */
  .dl {
    position: static;
    color: rgba(226, 228, 234, 0.92);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }
  .dl summary {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    padding: 0.45em 0.85em;
    background: rgba(17, 19, 24, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 999px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: background var(--t-fast), border-color var(--t-fast), color var(--t-fast);
  }
  .dl summary::-webkit-details-marker { display: none; }
  /* Hover and open use exactly the same surface so the pill doesn't flicker
     tone between "cursor over the Download button" and "menu open, cursor on
     the menu". */
  .dl summary:hover,
  .dl[open] summary {
    background: rgba(17, 19, 24, 0.92);
    border-color: var(--accent-line);
    color: var(--accent);
  }
  body[data-section="shards"] .dl summary { border-radius: 4px; }

  .dl-icon { width: 14px; height: 14px; }
  .dl-label { letter-spacing: 0.04em; }

  .dl-menu {
    position: absolute;
    top: calc(100% + var(--space-2));
    right: 0;
    /* An explicit floor sized for the worst-case row (Original line carrying
       a 4-digit resolution and the "original" badge). `width: max-content` is
       kept as well so shorter strings don't waste space, but the floor is
       what guarantees one-line items in every browser regardless of how the
       absolute-positioned shrink-to-fit calculation lands. */
    width: max-content;
    min-width: 360px;
    max-width: min(92vw, 520px);
    margin: 0;
    padding: var(--space-2) 0;
    list-style: none;
    background: rgba(17, 19, 24, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
  }
  body[data-section="shards"] .dl-menu { border-radius: 4px; }

  /* Grid (not flex) for the row: `auto auto` columns size to each child's
     content. Flex children can shrink below their content under
     `justify-content: space-between`, which is what was causing the label to
     wrap on first paint. */
  .dl-menu a {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: var(--space-3);
    padding: 0.55em var(--space-4);
    color: rgba(226, 228, 234, 0.92);
    border-bottom: none;
    white-space: nowrap;
    transition: background var(--t-fast), color var(--t-fast);
  }
  .dl-menu a:hover {
    background: var(--accent-soft);
    color: var(--accent);
    border-bottom: none;
  }
  .dl-opt-label {
    white-space: nowrap;
    min-width: 0;            /* lets grid track size honestly */
  }
  .dl-opt-badge {
    font-size: 0.78em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .dl-menu a:hover .dl-opt-badge { color: var(--accent); }

  @media (max-width: 640px) {
    .dl summary .dl-label { display: none; }
    .dl summary { padding: 0.5em; }
  }

  .tags {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border-soft);
  }
  .tags .label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    margin-right: var(--space-3);
  }
  .tags ul {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
    vertical-align: middle;
  }
</style>

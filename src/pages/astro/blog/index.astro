---
import { getCollection } from 'astro:content';
import SectionLayout from '../../../layouts/SectionLayout.astro';
import PostCard from '../../../components/PostCard.astro';

const posts = (await getCollection('astro-posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SectionLayout
  title="Astro — blog"
  description="Posts from the apeia.eu astrophotography blog."
  section="astro"
  eyebrow="Astro · Blog"
  heading="Notes from the dark."
  lede="Sessions, fixes, mistakes, the occasional surprise. Long enough to be useful, short enough to write."
  crumb={{ label: 'Astro', href: '/astro/' }}
>
  <section class="container">
    {posts.length === 0 ? (
      <p class="empty">No posts yet.</p>
    ) : (
      <ul class="list">
        {posts.map((p) => (
          <PostCard
            href={`/astro/blog/${p.slug}/`}
            title={p.data.title}
            date={p.data.date}
            summary={p.data.summary}
          />
        ))}
      </ul>
    )}
  </section>
</SectionLayout>

<style>
  .list { list-style: none; padding: 0; margin: 0; }
  .empty { color: var(--color-text-muted); padding: var(--space-7) 0; }
</style>

---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import OrbitalDecor from '../components/OrbitalDecor.astro';
import ShardDecor from '../components/ShardDecor.astro';
import { formatDate } from '../lib/format.ts';
import { getHomeBackgrounds } from '../lib/homeBackgrounds.ts';

const astroPosts = (await getCollection('astro-posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const shardsPosts = (await getCollection('shards-posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Every image tagged `home-page` (across both galleries) becomes a candidate
// background. We embed the optimised URLs and pick one client-side on load,
// so the choice is fresh each visit without a server.
const bgCandidates = await getHomeBackgrounds();
---

<Base title="apeia.eu" section="home">
  {bgCandidates.length > 0 && (
    <>
      <div class="page-bg" id="page-bg" aria-hidden="true"></div>
      <div class="page-bg-veil" aria-hidden="true"></div>
      <script is:inline define:vars={{ urls: bgCandidates.map((b) => b.src) }}>
        (() => {
          try {
            if (!Array.isArray(urls) || urls.length === 0) return;
            const el = document.getElementById('page-bg');
            if (!el) return;
            const url = urls[Math.floor(Math.random() * urls.length)];
            // Preload, then swap in — avoids a flash before the image arrives.
            const img = new Image();
            img.onload = () => {
              el.style.backgroundImage = 'url("' + url + '")';
              el.classList.add('is-loaded');
            };
            img.onerror = () => {
              // If the random pick fails, leave the deep-bg colour in place.
              el.classList.add('is-loaded');
            };
            img.src = url;
          } catch (_) { /* fail silent */ }
        })();
      </script>
    </>
  )}

  <section class="hero container-wide">
    <p class="kicker">apeia.eu</p>
    <h1>A site of memory and thought.</h1>
    <p class="sub">
      Two rooms in the same house. <span class="accent-astro">One looks up</span>;
      <span class="accent-shards">the other looks in</span>.
    </p>
  </section>

  <section class="container-wide split">
    <a class="card astro" href="/astro/">
      <OrbitalDecor variant="block" />
      <span class="eyebrow">Astro</span>
      <h2>Looking up</h2>
      <p>Backyard astrophotography — long exposures, capture notes, the nights it took to catch them.</p>
      <span class="more">Enter the gallery →</span>
    </a>

    <a class="card shards" href="/shards/">
      <ShardDecor variant="block" />
      <span class="eyebrow">Shards</span>
      <h2>Looking in</h2>
      <p>Essays and fragments on philosophy, science, politics — and travel notes when there are any.</p>
      <span class="more">Read the writing →</span>
    </a>
  </section>

  {(astroPosts.length > 0 || shardsPosts.length > 0) && (
    <section class="container-wide recent">
      {astroPosts.length > 0 && (
        <div class="col">
          <h3 class="col-title col-astro">Recent Astro</h3>
          <ul>
            {astroPosts.map((p) => (
              <li>
                <a href={`/astro/blog/${p.slug}/`}>
                  <span class="date">{formatDate(p.data.date)}</span>
                  <span class="t">{p.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
      {shardsPosts.length > 0 && (
        <div class="col">
          <h3 class="col-title col-shards">Recent Shards</h3>
          <ul>
            {shardsPosts.map((p) => (
              <li>
                <a href={`/shards/blog/${p.slug}/`}>
                  <span class="date">{formatDate(p.data.date)}</span>
                  <span class="t">{p.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}
</Base>

<style>
  /* ---- Random full-page background (tagged home-page) ---- */
  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -2;
    /* Cover preserves aspect ratio. May crop edges. */
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    background-color: var(--color-bg-deep);
    opacity: 0;
    transition: opacity 600ms ease;
  }
  .page-bg.is-loaded { opacity: 1; }

  /* Veil — keeps content readable over any image, but lets the photo breathe.
     Mostly clear at the top of the viewport (let the image speak), with a
     darker floor at the bottom so the recent-posts list stays legible.
     The cards on top already have their own frost; the veil doesn't need to
     dim the whole image. */
  .page-bg-veil {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(180deg,
        rgba(17,19,24,0.10) 0%,
        rgba(17,19,24,0.10) 35%,
        rgba(17,19,24,0.55) 80%,
        rgba(17,19,24,0.85) 100%);
  }

  /* When the random bg is active, drop the html-level radial accent gradient
     so it doesn't fight with the photograph. */
  :global(html:has(#page-bg)) { background-image: none; }

  .hero {
    position: relative;
    padding: var(--space-9) var(--space-5) var(--space-7);
    overflow: hidden;
    /* Subtle text shadow so headline stays legible over a bright patch of sky
       without us having to darken the whole image. */
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.55);
  }
  .kicker {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.18em;
    color: var(--color-text);
    opacity: 0.85;
    text-transform: uppercase;
  }
  .hero h1 {
    font-family: "Instrument Serif", Georgia, serif;
    font-size: var(--fs-hero);
    line-height: 1.05;
    max-width: 14ch;
    margin: 0 0 var(--space-5);
  }
  .hero .sub {
    color: rgba(226, 228, 234, 0.95);
    font-size: var(--fs-md);
    max-width: 56ch;
  }
  .accent-astro  { color: var(--color-accent-astro); }
  .accent-shards { color: var(--color-accent-shards); }

  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin: var(--space-7) auto;
    padding: 0 var(--space-5);
  }
  .card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 280px;
    padding: var(--space-6);
    /* Frosted surface so the cards read over any random photo behind */
    background: rgba(26, 29, 36, 0.62);
    backdrop-filter: blur(10px) saturate(115%);
    -webkit-backdrop-filter: blur(10px) saturate(115%);
    border: 1px solid var(--color-border-soft);
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border-soft);
    transition: border-color 200ms ease, transform 200ms ease, background 200ms ease;
  }
  .card :global(svg) {
    position: absolute;
    inset: -10% -20% auto auto;
    width: 70%;
    z-index: 0;
    opacity: 0.45;
    transition: opacity 200ms ease, transform 400ms ease;
  }
  .card:hover { transform: translateY(-2px); }
  .card:hover :global(svg) { opacity: 0.7; transform: scale(1.05); }
  .card > * { position: relative; z-index: 1; }

  /* astro card uses pill / round language */
  .astro { border-radius: var(--radius-lg); }
  .astro:hover     { border-color: var(--color-accent-astro);  background: rgba(122,162,247,0.04); }
  .astro .eyebrow  { color: var(--color-accent-astro); }
  .astro:hover .more { color: var(--color-accent-astro); }

  /* shards card uses cut corners */
  .shards { clip-path: var(--motif-shards-cut); border-radius: 0; }
  .shards:hover    { border-color: var(--color-accent-shards); background: rgba(187,154,247,0.04); }
  .shards .eyebrow { color: var(--color-accent-shards); }
  .shards:hover .more { color: var(--color-accent-shards); }

  .card .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 var(--space-3);
  }
  .astro h2  { font-family: "Instrument Serif", Georgia, serif; font-size: var(--fs-2xl); margin: 0 0 var(--space-3); }
  .shards h2 { font-family: "Fraunces", Georgia, serif;          font-size: var(--fs-2xl); margin: 0 0 var(--space-3); }
  .card p {
    color: rgba(226, 228, 234, var(--text-medium));
    margin: 0 0 var(--space-4);
    max-width: 36ch;
  }
  .more { font-size: var(--fs-sm); color: var(--color-text-muted); transition: color var(--t-fast); }

  .recent {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    margin: var(--space-8) auto;
    padding: 0 var(--space-5);
  }
  .col-title {
    margin: 0 0 var(--space-2);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border-soft);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .col-astro  { color: var(--color-accent-astro); }
  .col-shards { color: var(--color-accent-shards); }
  .col ul { list-style: none; padding: 0; margin: 0; }
  .col li { border-bottom: 1px solid var(--color-border-soft); }
  .col li:last-child { border-bottom: none; }
  .col a {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    align-items: baseline;
    color: var(--color-text);
    border-bottom: none;
  }
  .col a:hover .t { color: inherit; }
  .col .date { color: var(--color-text-muted); font-family: var(--font-mono); font-size: var(--fs-xs); }
  .col .t { transition: color var(--t-fast); }
  .col:nth-child(1) a:hover .t { color: var(--color-accent-astro); }
  .col:nth-child(2) a:hover .t { color: var(--color-accent-shards); }

  @media (max-width: 720px) {
    .split { grid-template-columns: 1fr; }
    .recent { grid-template-columns: 1fr; gap: var(--space-6); }
  }
</style>

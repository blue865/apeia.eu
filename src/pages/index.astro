---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import OrbitalDecor from '../components/OrbitalDecor.astro';
import ShardDecor from '../components/ShardDecor.astro';
import { formatDate } from '../lib/format.ts';
import { getHomeBackgrounds } from '../lib/homeBackgrounds.ts';

// Recent items per section are a *mix* of blog posts and galleries, sorted
// by date together so the list reads as "what's been added lately" rather
// than "what's been written lately".
type RecentItem = {
  title: string;
  date: Date;
  href: string;
  kind: 'post' | 'gallery';
};

const RECENT_LIMIT = 5;

const astroPostsRaw = await getCollection('astro-posts', ({ data }) => !data.draft);
const astroGalleriesRaw = await getCollection('astro-gallery', ({ data }) => !data.draft);
const shardsPostsRaw = await getCollection('shards-posts', ({ data }) => !data.draft);
const shardsGalleriesRaw = await getCollection('shards-gallery', ({ data }) => !data.draft);

function recentMix(
  posts: typeof astroPostsRaw,
  galleries: typeof astroGalleriesRaw,
  section: 'astro' | 'shards',
): RecentItem[] {
  const items: RecentItem[] = [
    ...posts.map((p) => ({
      title: p.data.title,
      date: p.data.date,
      href: `/${section}/blog/${p.id}/`,
      kind: 'post' as const,
    })),
    ...galleries.map((g) => ({
      title: g.data.title,
      date: g.data.date,
      href: `/${section}/gallery/${g.id}/`,
      kind: 'gallery' as const,
    })),
  ];
  items.sort((a, b) => b.date.valueOf() - a.date.valueOf());
  return items.slice(0, RECENT_LIMIT);
}

const astroRecent = recentMix(astroPostsRaw, astroGalleriesRaw, 'astro');
const shardsRecent = recentMix(shardsPostsRaw, shardsGalleriesRaw, 'shards');

// Every image tagged `home-page` (across both galleries) becomes a candidate
// background. We embed the optimised URLs and pick one client-side on load,
// so the choice is fresh each visit without a server.
const bgCandidates = await getHomeBackgrounds();
---

<Base title="apeia.eu" section="home">
  {bgCandidates.length > 0 && (
    <>
      <div class="page-bg" id="page-bg" aria-hidden="true"></div>
      <div class="page-bg-veil" aria-hidden="true"></div>
      <script is:inline define:vars={{
        picks: bgCandidates.map((b) => ({ src: b.src, a: b.accents.astro, s: b.accents.shards })),
      }}>
        (() => {
          try {
            if (!Array.isArray(picks) || picks.length === 0) return;
            const el = document.getElementById('page-bg');
            if (!el) return;
            const pick = picks[Math.floor(Math.random() * picks.length)];
            // Apply image-derived accents immediately so any chrome that paints
            // before the bg image finishes loading already uses the right tint.
            const root = document.documentElement;
            if (pick.a) root.style.setProperty('--color-accent-astro', pick.a);
            if (pick.s) root.style.setProperty('--color-accent-shards', pick.s);
            // Preload, then swap in — avoids a flash before the image arrives.
            const img = new Image();
            img.onload = () => {
              el.style.backgroundImage = 'url("' + pick.src + '")';
              el.classList.add('is-loaded');
            };
            img.onerror = () => {
              // If the random pick fails, leave the deep-bg colour in place.
              el.classList.add('is-loaded');
            };
            img.src = pick.src;
          } catch (_) { /* fail silent */ }
        })();
      </script>
    </>
  )}

  <section class="hero container-wide">
    <p class="kicker">/synoptics/</p>
    <h1>Mostly from the garden.</h1>
    <p class="sub">
      <span class="accent-astro">One looks up</span>;
      <span class="accent-shards">the other looks in</span>.
    </p>
  </section>

  <section class="container-wide split">
    <a class="card astro" href="/astro/">
      <OrbitalDecor variant="block" />
      <span class="eyebrow">Astro</span>
      <h2>Looking up</h2>
      <p>Long exposures guarded by cats: Gastonne, Guépardinne, Erwinne and the mighty Pedro.</p>
      <span class="more">Enter the gallery →</span>
    </a>

    <a class="card shards" href="/shards/">
      <ShardDecor variant="block" />
      <span class="eyebrow">Shards</span>
      <h2>Looking in</h2>
      <p>The Synoptic Gospels of a Society in Search of Meaning - gardening section.</p>
      <span class="more">Read the writing →</span>
    </a>
  </section>

  {(astroRecent.length > 0 || shardsRecent.length > 0) && (
    <section class="container-wide recent">
      {astroRecent.length > 0 && (
        <div class="col">
          <h3 class="col-title col-astro">Recent Astro</h3>
          <ul>
            {astroRecent.map((item) => (
              <li>
                <a href={item.href}>
                  <span class="date">{formatDate(item.date)}</span>
                  <span class="t">
                    {item.title}
                    {item.kind === 'gallery' && <span class="kind">gallery</span>}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
      {shardsRecent.length > 0 && (
        <div class="col">
          <h3 class="col-title col-shards">Recent Shards</h3>
          <ul>
            {shardsRecent.map((item) => (
              <li>
                <a href={item.href}>
                  <span class="date">{formatDate(item.date)}</span>
                  <span class="t">
                    {item.title}
                    {item.kind === 'gallery' && <span class="kind">gallery</span>}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}
</Base>

<style>
  /* ---- Random full-page background (tagged home-page) ---- */
  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -2;
    /* Cover preserves aspect ratio. May crop edges. */
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    background-color: var(--color-bg-deep);
    opacity: 0;
    transition: opacity 600ms ease;
  }
  .page-bg.is-loaded { opacity: 1; }

  /* Veil — keeps content readable over any image, but lets the photo breathe.
     Mostly clear at the top of the viewport (let the image speak), with a
     darker floor at the bottom so the recent-posts list stays legible.
     The cards on top already have their own frost; the veil doesn't need to
     dim the whole image. */
  .page-bg-veil {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(180deg,
        rgba(17,19,24,0.10) 0%,
        rgba(17,19,24,0.10) 35%,
        rgba(17,19,24,0.55) 80%,
        rgba(17,19,24,0.85) 100%);
  }

  /* When the random bg is active, drop the html-level radial accent gradient
     so it doesn't fight with the photograph. */
  :global(html:has(#page-bg)) { background-image: none; }

  .hero {
    position: relative;
    padding: var(--space-7) var(--space-5) var(--space-5);
    overflow: hidden;
    /* Subtle text shadow so headline stays legible over a bright patch of sky
       without us having to darken the whole image. */
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
  }
  .kicker {
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.18em;
    color: var(--color-text);
    opacity: 0.85;
    text-transform: uppercase;
  }
  .hero h1 {
    /* Home page borrows the Astro display face for visual continuity with
       the "looking up" half — it's also the heavier of the two displays. */
    font-family: var(--font-display-astro);
    font-size: var(--fs-xl);
    line-height: 1.15;
    max-width: 24ch;
    margin: 0 0 var(--space-3);
    letter-spacing: -0.01em;
    font-weight: 500;
  }
  .hero .sub {
    color: rgba(226, 228, 234, 0.82);
    font-size: var(--fs-sm);
    max-width: 56ch;
  }
  .accent-astro  { color: var(--color-accent-astro); }
  .accent-shards { color: var(--color-accent-shards); }

  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin: var(--space-7) auto;
    padding: 0 var(--space-5);
  }
  .card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 280px;
    padding: var(--space-6);
    /* Frosted surface so the cards read over any random photo behind */
    background: rgba(26, 29, 36, 0.62);
    backdrop-filter: blur(10px) saturate(115%);
    -webkit-backdrop-filter: blur(10px) saturate(115%);
    border: 1px solid var(--color-border-soft);
    color: var(--color-text);
    border-bottom: 1
    border-bottom: 1px solid var(--color-border-soft);
    transition: border-color 200ms ease, transform 200ms ease, background 200ms ease;
  }
  .card :global(svg) {
    position: absolute;
    inset: -10% -20% auto auto;
    width: 70%;
    z-index: 0;
    opacity: 0.45;
    transition: opacity 200ms ease, transform 400ms ease;
  }
  .card:hover { transform: translateY(-2px); }
  .card:hover :global(svg) { opacity: 0.7; transform: scale(1.05); }
  .card > * { position: relative; z-index: 1; }

  /* astro card — circular language */
  .astro { border-radius: var(--radius-lg); }
  .astro:hover     { border-color: var(--color-accent-astro); background: rgba(93, 214, 200, 0.05); }
  .astro .eyebrow  { color: var(--color-accent-astro); }
  .astro:hover .more { color: var(--color-accent-astro); }

  /* shards card — angular / shard language */
  .shards { clip-path: var(--motif-shards-cut); border-radius: 0; }
  .shards:hover    { border-color: var(--color-accent-shards); background: rgba(232, 168, 124, 0.05); }
  .shards .eyebrow { color: var(--color-accent-shards); }
  .shards:hover .more { color: var(--color-accent-shards); }

  .card .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 var(--space-3);
  }
  .astro  h2 { font-family: var(--font-display-astro);  font-size: var(--fs-2xl); margin: 0 0 var(--space-3); letter-spacing: -0.02em; }
  .shards h2 { font-family: var(--font-display-shards); font-size: var(--fs-2xl); margin: 0 0 var(--space-3); }
  .card p {
    color: rgba(226, 228, 234, var(--text-medium));
    margin: 0 0 var(--space-4);
    max-width: 36ch;
  }
  .more {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    transition: color var(--t-fast);
  }

  /* ----- Recent posts grid (the part that was missing) ----- */
  .recent {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-7);
    margin: var(--space-8) auto;
    padding: 0 var(--space-5);
  }
  .col-title {
    margin: 0 0 var(--space-2);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border-soft);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .col-astro  { color: var(--color-accent-astro); }
  .col-shards { color: var(--color-accent-shards); }

  .col ul { list-style: none; padding: 0; margin: 0; }
  .col li { border-bottom: 1px solid var(--color-border-soft); }
  .col li:last-child { border-bottom: none; }
  .col a {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    align-items: baseline;
    color: var(--color-text);
    border-bottom: none;
  }
  .col .date {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
  }
  .col .t { transition: color var(--t-fast); }
  .col:nth-child(1) a:hover .t { color: var(--color-accent-astro); }
  .col:nth-child(2) a:hover .t { color: var(--color-accent-shards); }

  /* Subtle "gallery" tag after a title — same family as the date column,
     a touch smaller so it reads as a postfix annotation rather than part
     of the title. Posts get no badge (they're the implicit default). */
  .col .kind {
    margin-left: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.7em;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    opacity: 0.75;
    vertical-align: 0.05em;
  }

  @media (max-width: 720px) {
    .split  { grid-template-columns: 1fr; }
    .recent { grid-template-columns: 1fr; gap: var(--space-6); }
  }
</style>

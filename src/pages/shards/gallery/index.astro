---
import { getCollection } from 'astro:content';
import SectionLayout from '../../../layouts/SectionLayout.astro';
import GalleryCard from '../../../components/GalleryCard.astro';

const galleries = (await getCollection('shards-gallery', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SectionLayout
  title="Shards — gallery"
  description="Image collections in the Shards section — usually travel, occasionally something else."
  section="shards"
  eyebrow="Shards · Gallery"
  heading="Image collections."
  lede="Loose visual notebooks — places, things, sometimes people. Captions where they help, silence where they don't."
  crumb={{ label: 'Shards', href: '/shards/' }}
>
  <section class="container-wide">
    {galleries.length === 0 ? (
      <p class="empty">No galleries yet.</p>
    ) : (
      <ul class="grid">
        {galleries.map((g) => {
          const slug = g.id;
          const cover = g.data.cover ?? g.data.images?.[0]?.file;
          return (
            <li>
              <GalleryCard
                href={`/shards/gallery/${slug}/`}
                title={g.data.title}
                date={g.data.date}
                cover={cover}
                description={g.data.description}
                count={g.data.images.length}
                section="shards"
              />
            </li>
          );
        })}
      </ul>
    )}
  </section>
</SectionLayout>

<style>
  .grid {
    list-style: none; padding: 0;
    margin: 0 auto var(--space-7);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-5);
  }
  .empty { col